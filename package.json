{
  "name": "th-whats",
  "version": "1.2.0",
  "description": "TH-WHATS - Cliente profesional de WhatsApp Business para Tunerhouse",
  "main": "main.js",
  "author": "Tunerhouse",
  "license": "MIT",
  "scripts": {
    "start":     "electron .",
    "dev":       "electron . --dev",
    "build":     "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir",
    "pack":      "electron-builder --dir"
  },
  "dependencies": {
    "whatsapp-web.js": "^1.23.0",
    "qrcode":          "^1.5.3"
  },
  "devDependencies": {
    "electron":         "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId":       "com.tunerhouse.th-whats",
    "productName": "TH-WHATS",
    "copyright":   "Copyright © 2025 Tunerhouse",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/**/*.map",
      "!node_modules/**/*.md",
      "!**/.wwebjs_auth/**",
      "!**/.wwebjs_cache/**",
      "!**/th-whats-*.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch":   ["x64"]
        },
        {
          "target": "portable",
          "arch":   ["x64"]
        }
      ],
      "icon": "assets/tray-icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick":              false,
      "perMachine":            false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon":         "assets/tray-icon.ico",
      "uninstallerIcon":       "assets/tray-icon.ico",
      "installerHeaderIcon":   "assets/tray-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName":          "TH-WHATS",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "TH-WHATS-${version}-portable.exe"
    },
    "extraResources": [],
    "asar": true,
    "compression": "maximum",
    "publish": null
  }
}
